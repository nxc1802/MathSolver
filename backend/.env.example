# --- OpenRouter (Model Fallback Sequence) ---
OPENROUTER_API_KEY_1="sk-or-v1-..."
OPENROUTER_MODEL_1="openai/gpt-oss-120b:free"
OPENROUTER_MODEL_2="meta-llama/llama-3.3-70b-instruct:free"
OPENROUTER_MODEL_3="google/gemini-2.0-flash-001"

# --- Supabase (Database & Storage) ---
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_BUCKET="video"
# Chat / solve multipart image uploads (separate from video bucket)
SUPABASE_IMAGE_BUCKET="image"

# --- Redis & Celery (Queues) ---
# If using local docker-compose, use redis://redis:6379/0
REDIS_URL="redis://localhost:6379/0"
CELERY_BROKER_URL="redis://localhost:6379/0"
CELERY_RESULT_BACKEND="redis://localhost:6379/0"

# --- OCR offload (optional dedicated Celery worker, queue `ocr`) ---
# When true, orchestrator and /ocr / ocr_preview run OCR via Celery instead of in-process.
OCR_USE_CELERY=false
OCR_CELERY_TIMEOUT_SEC=180

# --- Feature Flags ---
ALLOW_TEST_BYPASS=false
MOCK_VIDEO=false
CELERY_TASK_ALWAYS_EAGER=false
PORT=7860

# --- Integration tests (scripts/prepare_api_test.py, pytest) ---
# Must be an existing auth.users id in your Supabase project (FK on sessions).
TEST_SUPABASE_USER_ID=
# Opt-in heavy OCR/Manim worker tests (see backend/scripts/run_real_integration.sh).
RUN_REAL_WORKER_OCR=0
RUN_REAL_WORKER_MANIM=0
# Public image URL for OCR worker / agent tests.
TEST_OCR_IMAGE_URL=
